# Server Configuration
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=adapt_db
DB_USER=adapt_user
DB_PASSWORD=adapt_password

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY=7d

# Engine Service Integration
ENGINE_SERVICE_URL=http://localhost:4001

# Frontend origin allowed by CORS (production: https://your-frontend-domain)
FRONTEND_URL=http://localhost:3000

# Optional comma-separated extra origins
# ALLOWED_ORIGINS=https://admin.example.com,https://app.example.com
