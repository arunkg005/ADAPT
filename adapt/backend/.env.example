# Server Configuration
NODE_ENV=development
PORT=3001
API_BASE_URL=http://localhost:3001

# PostgreSQL Database
# Preferred in cloud environments (Render/Railway/etc)
# DATABASE_URL=postgres://user:password@host:5432/database
# DB_SSL=false

# Alternative host-based configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=adapt_db
DB_USER=adapt_user
DB_PASSWORD=adapt_password

# JWT Authentication
# Production requirement: set to a strong random value (minimum 32 characters)
JWT_SECRET=replace-with-a-strong-secret-at-least-32-characters
JWT_EXPIRY=7d

# Engine Service Integration
ENGINE_SERVICE_URL=http://localhost:4001
# Optional host/port alternative (used when ENGINE_SERVICE_URL is not set)
# ENGINE_SERVICE_HOST=localhost
# ENGINE_SERVICE_PORT=4001

# Frontend origin allowed by CORS (production: https://your-frontend-domain)
FRONTEND_URL=http://localhost:3000

# Optional comma-separated extra origins
# ALLOWED_ORIGINS=https://admin.example.com,https://app.example.com

# Request and rate-limit hardening
REQUEST_BODY_LIMIT=1mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
AUTH_RATE_LIMIT_MAX=40
