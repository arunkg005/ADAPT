<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/windowBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/task_lab_header_title"
            android:textColor="@color/text_primary"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="20dp"
            android:text="@string/task_lab_header_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- Imported AI Draft (shown when available) -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardImportedDraft"
            style="@style/Widget.Adapt.Card.Warning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New AI Draft"
                    android:textColor="@color/warning_text"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <TextView
                    android:id="@+id/tvImportedDraftTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Draft title"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvImportedDraftDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Draft description"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvImportedDraftTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Scheduled time: --"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPublishImportedDraft"
                        style="@style/Widget.Adapt.Button.Primary"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:text="Publish"
                        />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDiscardImportedDraft"
                        style="@style/Widget.Adapt.Button.Text"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Discard" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Templates Section — Clean list style -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/task_lab_templates_section"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTemplateMedication"
            style="@style/Widget.Adapt.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="💊  Medication Support"
            android:textSize="15sp"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTemplateDailyCare"
            style="@style/Widget.Adapt.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="🏠  Daily Care"
            android:textSize="15sp"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnTemplateWellness"
            style="@style/Widget.Adapt.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"
            android:text="🧘  Wellness"
            android:textSize="15sp"
            android:gravity="start|center_vertical"
            android:paddingStart="16dp" />

        <!-- AI Planner — Simple prompt entry -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/task_lab_ai_section"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold"
            android:layout_marginBottom="6dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/task_lab_ai_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenAiPlanner"
            style="@style/Widget.Adapt.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="24dp"
            android:text="Open AI Planner"
            android:textSize="15sp"
            app:icon="@android:drawable/ic_input_add"
            app:iconGravity="textStart"
            app:iconTint="@color/white" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
