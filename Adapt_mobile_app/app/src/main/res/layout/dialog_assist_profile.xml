<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="8dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Configure pre-handover controls for this assist session."
        android:textColor="@color/text_secondary"
        android:textSize="13sp" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchVoiceGuidance"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Voice guidance"
        android:textColor="@color/text_primary" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchLargeText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Large text and controls"
        android:textColor="@color/text_primary" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchDoubleConfirm"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Restrict fast skipping (double confirm)"
        android:textColor="@color/text_primary" />

    <com.google.android.material.switchmaterial.SwitchMaterial
        android:id="@+id/switchAdaptivePrompts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Adaptive attention prompts"
        android:textColor="@color/text_primary" />

</LinearLayout>
