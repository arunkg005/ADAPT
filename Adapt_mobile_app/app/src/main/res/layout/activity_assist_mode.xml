<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/windowBackground">

    <LinearLayout
        android:id="@+id/llFocusedContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        app:layout_constraintBottom_toTopOf="@+id/btnCaretakerUnlock"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Adapt.Card.Tint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/TextAppearance.Adapt.SectionLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/assist_hands_free_label"
                    android:textColor="@color/primaryBlueDark" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="3dp"
                    android:text="@string/assist_hands_free_body"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Minimal header -->
        <TextView
            android:id="@+id/tvAssistHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/nav_assist_mode"
            android:textColor="@color/primaryBlue"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.05"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvAssistGreeting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:text="One step at a time. You've got this."
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <!-- Current routine card — the main focus -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.Adapt.Card.Surface"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="2dp"
            app:strokeColor="@color/primaryBlue"
            app:strokeWidth="1.5dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:id="@+id/tvAssistRoutineLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Current Routine"
                    android:textColor="@color/primaryBlue"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05" />

                <TextView
                    android:id="@+id/tvAssistRoutineTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="No routine selected"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAssistRoutineDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Select a routine from Tasks to begin."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvAssistProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Progress: --"
                    android:textColor="@color/primaryBlue"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Primary action -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnViewActiveTask"
            style="@style/Widget.Adapt.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="Open Current Task"
            android:textSize="17sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <!-- Secondary actions row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNextGuidance"
                style="@style/Widget.Adapt.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="Next Hint"
                />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNeedHelpNow"
                style="@style/Widget.Adapt.Button.DangerSoft"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="Need Help" />
        </LinearLayout>

        <!-- Hint text -->
        <TextView
            android:id="@+id/tvAssistHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Take a breath. Read the step slowly."
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="16dp" />

        <!-- Collapsible session settings -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAssistSession"
            style="@style/Widget.Adapt.Card.Tint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:letterSpacing="0.05"
                    android:text="Session Settings"
                    android:textColor="@color/primaryBlue"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvAssistSessionSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Voice ON · Large text ON · Double confirm ON"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnReadGuidance"
                        style="@style/Widget.Adapt.Button.Outlined"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="Guidance"
                        android:textSize="13sp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnConfigureAssistSession"
                        style="@style/Widget.Adapt.Button.Primary"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Configure"
                        android:textSize="13sp" />
                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnConfigureRoutineRestrictions"
                    style="@style/Widget.Adapt.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="38dp"
                    android:layout_marginTop="8dp"
                    android:text="Task Restrictions"
                    android:textSize="12sp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Lock icon (kept but smaller/subtler) -->
        <ImageView
            android:id="@+id/ivAssistLock"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="20dp"
            android:src="@android:drawable/ic_lock_lock"
            app:tint="@color/icon_muted"
            android:alpha="0.6" />

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCaretakerUnlock"
        style="@style/Widget.Adapt.Button.Text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Caregiver: Hold to Unlock"
        android:textSize="12sp"
        android:layout_marginBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
