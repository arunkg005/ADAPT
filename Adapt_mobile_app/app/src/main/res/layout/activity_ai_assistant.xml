<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarAiAssistant"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        app:navigationIcon="@android:drawable/ic_menu_revert"
        app:navigationIconTint="@color/primaryBlue"
        app:title="AI Assistant"
        app:titleCentered="true"
        app:titleTextColor="@color/primaryBlue" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnQuickMedication"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:text="Medication"
                    android:textAllCaps="false"
                    android:textColor="@color/primaryBlue"
                    android:backgroundTint="@color/lightBlue" />

                <Button
                    android:id="@+id/btnQuickFallRisk"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:layout_marginEnd="8dp"
                    android:text="Fall Risk"
                    android:textAllCaps="false"
                    android:textColor="@color/primaryBlue"
                    android:backgroundTint="@color/lightBlue" />

                <Button
                    android:id="@+id/btnQuickRoutine"
                    android:layout_width="wrap_content"
                    android:layout_height="42dp"
                    android:text="Routine"
                    android:textAllCaps="false"
                    android:textColor="@color/primaryBlue"
                    android:backgroundTint="@color/lightBlue" />
            </LinearLayout>
        </HorizontalScrollView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardGeneratedPlan"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="16dp"
            app:strokeColor="@color/lightBlue"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Generated Plan Draft"
                    android:textAllCaps="true"
                    android:textColor="@color/primaryBlue"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvGeneratedPlanTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="No draft yet"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvGeneratedPlanDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Send a prompt and the assistant will produce a Task Lab draft."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvGeneratedPlanTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Suggested time: --"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnSendToTaskLab"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/primaryBlue"
                    android:enabled="false"
                    android:text="Send Draft to Task Lab"
                    android:textAllCaps="false"
                    android:textColor="@color/white" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="12dp"
            android:background="@drawable/glass_card_bg"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvConversation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <EditText
                android:id="@+id/etAssistantPrompt"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/glass_card_bg"
                android:hint="Ask the assistant..."
                android:padding="12dp"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />

            <Button
                android:id="@+id/btnSendPrompt"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_marginStart="10dp"
                android:text="Send"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:backgroundTint="@color/primaryBlue" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
