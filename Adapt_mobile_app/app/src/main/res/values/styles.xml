<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.Adapt.SectionLabel" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.08</item>
    </style>

    <style name="TextAppearance.Adapt.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Widget.Adapt.Card.Surface" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">@dimen/adapt_card_radius</item>
        <item name="cardElevation">0dp</item>
        <item name="cardBackgroundColor">@color/cardBackground</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Adapt.Card.Tint" parent="Widget.Adapt.Card.Surface">
        <item name="cardBackgroundColor">@color/lightBlue</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="Widget.Adapt.Card.Warning" parent="Widget.Adapt.Card.Surface">
        <item name="cardBackgroundColor">@color/warning_surface</item>
        <item name="strokeColor">@color/warning_border</item>
    </style>

    <style name="Widget.Adapt.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/primaryBlue</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.Adapt.Button.Secondary" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/primaryBlue</item>
        <item name="backgroundTint">@color/lightBlue</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.Adapt.Button.DangerSoft" parent="Widget.MaterialComponents.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/danger</item>
        <item name="backgroundTint">@color/danger_surface</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.Adapt.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="backgroundTint">@color/white</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.Adapt.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="Widget.Adapt.Button.IconPrimary" parent="Widget.Adapt.Button.Primary">
        <item name="iconTint">@color/white</item>
        <item name="iconPadding">0dp</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.Adapt.TextInputLayout.Outlined" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="boxStrokeColor">@color/divider</item>
        <item name="boxBackgroundColor">@color/cardBackground</item>
    </style>

    <style name="Widget.Adapt.Chip.Choice" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/lightBlue</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="android:textColor">@color/primaryBlue</item>
        <item name="chipCornerRadius">10dp</item>
    </style>

    <style name="Widget.Adapt.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/bottom_nav_surface</item>
        <item name="itemRippleColor">@color/lightBlueStrong</item>
    </style>

    <style name="ShapeAppearance.Adapt.Fab" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">18dp</item>
    </style>

    <style name="ShapeAppearance.Adapt.FabMini" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">14dp</item>
    </style>

</resources>